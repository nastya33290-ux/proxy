{
  "manifest_version": 3,
  "name": "Proxy Switcher Pro for Edge",
  "version": "1.2.1",
  "description": "Управление множеством прокси (HTTP/HTTPS/SOCKS5) в Microsoft Edge: быстрый выбор, вкл/выкл, случайный прокси, проверка IP, исключения.",
  "permissions": ["proxy", "storage", "tabs", "webRequest", "webRequestAuthProvider"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Proxy Switcher Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
